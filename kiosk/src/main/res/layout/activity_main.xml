<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#102A43"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="매쓰홀릭 QR 키오스크 · Gate 4"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="준비 중"
                android:textColor="#D9EAF7"
                android:textSize="16sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/auth_panel"
                android:layout_width="480dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="#FFFFFF"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:id="@+id/auth_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="관리자 PIN 설정"
                    android:textColor="#102A43"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/auth_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="숫자 6~12자리 PIN을 기기 안에서 설정하세요."
                    android:textColor="#486581"
                    android:textSize="16sp" />

                <EditText
                    android:id="@+id/pin_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="관리자 PIN"
                    android:importantForAutofill="no"
                    android:inputType="numberPassword"
                    android:maxLength="12"
                    android:saveEnabled="false" />

                <EditText
                    android:id="@+id/pin_confirm_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="PIN 확인"
                    android:importantForAutofill="no"
                    android:inputType="numberPassword"
                    android:maxLength="12"
                    android:saveEnabled="false" />

                <TextView
                    android:id="@+id/auth_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#B00020"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/auth_submit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="설정" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/admin_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="20dp"
                android:visibility="gone">

                <ScrollView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="20dp"
                    android:layout_weight="1.35"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="반 관리"
                            android:textColor="#102A43"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/class_name_input"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="새 반 이름"
                                android:maxLength="40" />

                            <Button
                                android:id="@+id/create_class_button"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="반 생성" />
                        </LinearLayout>

                        <Spinner
                            android:id="@+id/class_spinner"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="학생 등록"
                            android:textColor="#102A43"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/student_name_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:hint="매쓰홀릭 표시명(정확히)"
                            android:maxLength="80" />

                        <EditText
                            android:id="@+id/student_masked_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="마스킹 표시명(예: 홍*동)"
                            android:maxLength="80" />

                        <EditText
                            android:id="@+id/username_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="매쓰홀릭 아이디"
                            android:importantForAutofill="no"
                            android:inputType="textNoSuggestions"
                            android:saveEnabled="false" />

                        <EditText
                            android:id="@+id/password_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="매쓰홀릭 비밀번호"
                            android:importantForAutofill="no"
                            android:inputType="textPassword"
                            android:saveEnabled="false" />

                        <Button
                            android:id="@+id/register_student_button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="암호화 등록 및 QR 발급" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="등록 학생"
                            android:textColor="#102A43"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/student_spinner"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/reissue_qr_button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="QR 폐기·재발급" />

                            <Button
                                android:id="@+id/add_temporary_button"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="현재 수업 보강 추가"
                                android:visibility="gone" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/start_session_button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="16dp"
                            android:text="선택한 반 수업 시작" />

                        <Button
                            android:id="@+id/resume_session_button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:text="QR 대기 화면으로 복귀"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/admin_message"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textColor="#334E68"
                            android:textSize="15sp" />
                    </LinearLayout>
                </ScrollView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.8"
                    android:background="#FFFFFF"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/qr_card_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="발급한 QR은 이 화면에 한 번만 표시됩니다"
                        android:textColor="#102A43"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/qr_image"
                        android:layout_width="360dp"
                        android:layout_height="360dp"
                        android:layout_marginTop="16dp"
                        android:contentDescription="발급된 학생 QR"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="화면 캡처·클립보드·외부 파일 저장은 차단됩니다. 재출력은 새 QR 재발급을 사용하세요."
                        android:textColor="#627D98"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/scanner_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <androidx.camera.view.PreviewView
                    android:id="@+id/camera_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:implementationMode="performance"
                    app:scaleType="fillCenter" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#33000000" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#DD102A43"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/scanner_message"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="QR카드를 카메라에 보여주세요"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/session_admin_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="관리자" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
